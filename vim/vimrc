" 提示：如果需要了解选项含义，可使用 :help <选项名> 查看帮助
set clipboard=unnamedplus        " 使用系统剪贴板（需 Vim 编译支持 +clipboard）
set completeopt=menu,menuone,noselect " 补全选项配置
set mouse=a                      " 允许在 Vim 中使用鼠标

" 制表符（Tab）相关配置
set tabstop=4                    " 每个 TAB 键显示的视觉空格数
set softtabstop=4                " 编辑时 TAB 键对应的空格数
set shiftwidth=4                 " 自动缩进时插入的空格数
set expandtab                    " 将 TAB 转换为空格（主要适配 Python 开发）

" 界面（UI）相关配置
set number                       " 显示绝对行号
set relativenumber               " 左侧显示相对行号（当前行仍为绝对行号）
set cursorline                   " 高亮光标所在行
set splitbelow                   " 新建水平分割窗口时，窗口在下方打开
set splitright                   " 新建垂直分割窗口时，窗口在右侧打开
" set termguicolors              " 在终端中启用 24 位 RGB 真彩色（视终端支持情况开启）
set noshowmode                   " 隐藏模式提示（如 -- INSERT --）

" 搜索相关配置
set incsearch                    " 输入搜索字符时实时预览匹配结果
set nohlsearch                   " 不高亮显示搜索匹配结果
set ignorecase                   " 搜索默认忽略大小写
set smartcase                    " 若搜索内容包含大写字母，则开启大小写敏感

" 快捷键映射：Ctrl+Shift+C 复制内容到系统剪贴板
" 可视模式：复制选中的内容
vnoremap <C-S-c> "+y
" 普通模式：复制当前整行
nnoremap <C-S-c> "+yy
